{
  "expo": {
    "name": "Kharcha",
    "slug": "kharcha-app",
    "scheme": "kharcha",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0A"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kharcha.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.kharcha.expense.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/app-icon.png",
        "backgroundColor": "#0A0A0A"
      },
      "permissions": ["android.permission.READ_SMS", "android.permission.RECEIVE_SMS"],
      "privacyUrl": "https://ayushhgupta39.github.io/kharcha-privacy-policy/"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": ["expo-sqlite", "expo-font"],
    "experiments": {
      "tsconfigPaths": true
    },
    "extra": {
      "eas": {
        "projectId": "48d20783-29a2-4f36-b618-956baeb132db"
      }
    }
  }
}
